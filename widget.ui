       <property name="styleSheet">
        <string notr="true">QLabel {
    /* 战术底板：深沉的枪灰色，带有较高的不透明度，确保文字清晰 */
    background-color: rgba(25, 28, 33, 220);
    
    /* 字体：纯白，冷酷专业 */
    color: #FFFFFF;
    font-family: &quot;Microsoft YaHei&quot;, sans-serif;
    font-size: 20px; 
    font-weight: bold;
    letter-spacing: 3px; /* 微微拉开字间距 */
    
    /* 核心灵魂：左侧的粗壮 CS2 警戒黄切线 */
    border-left: 5px solid #EAA112;
    
    /* 底部加一条极细的暗线，增加装甲拼接的质感 */
    border-bottom: 2px solid rgba(255, 255, 255, 15);
    
    /* 切角设计：右上和左下有微小的圆角，左上和右下直角，充满机械感 */
    border-top-right-radius: 6px;
    border-bottom-left-radius: 6px;
    
    /* 留出舒适的内边距 */
    padding: 8px 20px; 
}</string>
