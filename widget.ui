       </property>
       <property name="styleSheet">
        <string notr="true">QLabel {
    /* 底板：非常高级的深灰色半透明遮罩，不会完全挡住背后的看海士兵 */
    background-color: rgba(20, 22, 25, 180);
    
    /* 字体：使用 CS2 经典的亮黄 */
    color: #EAA112; 
    font-family: &quot;Microsoft YaHei&quot;, sans-serif;
    font-size: 36px; /* 标题必须要大！ */
    font-weight: bold;
    font-style: italic; /* 倾斜字体更有冲刺和枪战的动感 */
    letter-spacing: 6px; /* 字间距拉大，霸气外露 */
    
    /* 边框：上下加上极细的高光线，非常有科幻感 */
    border-top: 2px solid #EAA112;
    border-bottom: 2px solid rgba(255, 255, 255, 30);
    
    /* 圆角和内边距 */
    border-radius: 8px;
    padding: 10px 40px; /* 左右稍微留白，做成一个长条形的横幅效果 */
}</string>
       </property>
       <property name="text">
        <string>CS2:Major传奇荟萃</string>
       </property>
      </widget>
      <widget class="QWidget" name="layoutWidget">
       <property name="geometry">
        <rect>
