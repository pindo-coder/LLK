      <widget class="QLabel" name="label_2">
       <property name="geometry">
        <rect>
         <x>130</x>
         <y>10</y>
         <width>471</width>
         <height>121</height>
        </rect>
       </property>
       <property name="font">
        <font>
         <family>Impact</family>
         <pointsize>-1</pointsize>
         <italic>true</italic>
