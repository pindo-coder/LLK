      <widget class="QLabel" name="label_timeCost">
       <property name="geometry">
        <rect>
         <x>160</x>
         <y>140</y>
         <width>341</width>
         <height>141</height>
        </rect>
       </property>
       <property name="styleSheet">
        <string notr="true">QLabel {
    /* 核心亮点：从左到右的半透明渐变底色，左侧微微泛黄，右侧融入黑夜 */
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 rgba(234, 161, 18, 60), stop:1 rgba(30, 32, 36, 200));
    
    /* 字体设置：纯白高亮，加粗显示 */
    color: #FFFFFF;
    font-family: &quot;Microsoft YaHei&quot;, sans-serif;
    font-size:15px; /* 字体要大，突出成绩 */
    font-weight: 900; /* 极致加粗 */
    letter-spacing: 2px; /* 稍微拉开字间距，更显高级 */
    
    /* 边框设计：左侧加粗警戒黄高光，其余三边极细半透明白边 */
    border-left: 6px solid #EAA112; 
    border-top: 1px solid rgba(255, 255, 255, 20);
    border-bottom: 1px solid rgba(255, 255, 255, 20);
    border-right: 1px solid rgba(255, 255, 255, 20);
    
    /* 微小圆角和舒适的内边距 */
    border-radius: 4px;
    padding: 20px; 
}</string>
