       <property name="styleSheet">
        <string notr="true">QLabel {
    /* 核心底色：从左侧的血红色渐变到右侧的死寂黑 */
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 rgba(220, 20, 60, 80), stop:1 rgba(20, 20, 22, 220));
    
    /* 字体：冷酷的纯白 */
    color: #FFFFFF;
    font-family: &quot;Microsoft YaHei&quot;, &quot;Impact&quot;, sans-serif;
    font-size: 22px; 
    font-weight: 900; 
    letter-spacing: 3px; 
    
    /* 边框：左侧变成粗壮的警报红边框 */
    border-left: 6px solid #DC143C; /* 猩红色 */
    border-top: 1px solid rgba(255, 255, 255, 15);
    border-bottom: 1px solid rgba(255, 255, 255, 15);
    border-right: 1px solid rgba(255, 255, 255, 15);
    
    border-radius: 4px;
    padding: 20px; 
}</string>
