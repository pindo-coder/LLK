       <layout class="QVBoxLayout" name="verticalLayout_2">
        <item>
         <widget class="QPushButton" name="pushButton_4">
          <property name="font">
           <font>
            <family>Microsoft YaHei</family>
            <pointsize>-1</pointsize>
            <bold>true</bold>
           </font>
          </property>
          <property name="styleSheet">
           <string notr="true">/* ================= 常态（默认样子） ================= */
QPushButton {
    background-color: rgba(30, 32, 36, 180); /* 深色枪灰色，带一点透明度透出背景 */
    color: #FFFFFF; /* 纯白字体 */
    border: 2px solid rgba(255, 255, 255, 30); /* 极淡的白色边框，增加质感 */
    border-radius: 4px; /* 微小的圆角，现代感更强 */
    font-family: &quot;Microsoft YaHei&quot;, sans-serif; /* 干净的无衬线字体 */
    font-size: 14px; /* 字体大小（根据你的实际按钮大小微调） */
    font-weight: bold;
    letter-spacing: 4px; /* 字间距拉宽，显得更高级 */
}

/* ================= 悬停态（鼠标放上去时） ================= */
QPushButton:hover {
    background-color: rgba(45, 48, 54, 220); /* 底色稍微变亮一点 */
    color: #EAA112; /* 字体变成 CS2 标志性的亮黄色 */
    border: 2px solid #EAA112; /* 边框亮起警戒黄 */
}

/* ================= 按下态（鼠标点击时） ================= */
QPushButton:pressed {
    background-color: #EAA112; /* 点击瞬间底色变成全黄 */
    color: #000000; /* 字体变成黑色，形成强烈反差 */
    border: 2px solid #EAA112;
    padding-top: 2px; /* 模拟真实的向下按压物理位移 */
    padding-left: 2px;
}</string>
          </property>
          <property name="text">
           <string>排行榜</string>
          </property>
