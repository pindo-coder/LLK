        </font>
       </property>
       <property name="styleSheet">
        <string notr="true">QLabel {
    /* 核心特效：中间亮、两边暗的“探照灯”渐变底色，营造高光时刻的舞台感 */
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 rgba(0, 0, 0, 0), stop:0.5 rgba(234, 161, 18, 60), stop:1 rgba(0, 0, 0, 0));
    
    /* 字体设置：闪耀的冠军金 */
    color: black; 
    
    /* 使用 Impact 这种厚重的海报字体，如果没有会自动降级为雅黑粗体 */
    font-family: &quot;Impact&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
    
    /* 字体必须要巨大！ */
    font-size: 56px; 
    font-weight: 900;
    
    /* 倾斜字体能带来极强的速度感和力量感 */
    font-style: italic; 
    
    /* 字间距拉开，彰显霸气 */
    letter-spacing: 8px; 
    
    /* 上下留出内边距，防止被框体切断 */
    padding: 15px 0px; 
}</string>
       </property>
